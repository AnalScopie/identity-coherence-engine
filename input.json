def run():
    with open("input.json", "r") as f:
        data = json.load(f)

    result, log = process_identity(data)

    with open("output.json", "w") as f:
        json.dump(result, f, indent=2)

    with open("audit.log", "w") as f:
        f.write(f"Audit log - {datetime.now()}\n\n")
        for entry in log:
            f.write(entry + "\n")

